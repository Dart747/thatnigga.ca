# Hormuz Terminal — required environment variables
# Copy this file to .env and fill in your API keys.

# AIS Stream API key (https://aisstream.io)
AIS_API_KEY=your_aisstream_key_here

# Alpha Vantage API key for Brent crude price data (https://www.alphavantage.co)
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# GIE AGSI+ API key for EU gas storage data (https://agsi.gie.eu)
# Required — requests without this header return empty results.
GIE_API_KEY=your_gie_agsi_key_here
